* @ingroup iface_wl_data_source
*/
WL_DATA_SOURCE_DND_FINISHED_SINCE_VERSION :: 3

/**
* @ingroup iface_wl_data_source
*/
WL_DATA_SOURCE_ACTION_SINCE_VERSION :: 3

/**
* @ingroup iface_wl_data_source
*/
WL_DATA_SOURCE_OFFER_SINCE_VERSION :: 1

