/**
* @ingroup iface_wl_region
* @struct wl_region_interface
*/
region_interface :: struct {
	/**
	* destroy region
	*
	* Destroy the region. This will invalidate the object ID.
	*/
	destroy: proc "c" (client: ^client, resource: ^resource),

	/**
	* add rectangle to region
	*
	* Add the specified rectangle to the region.
	* @param x region-local x coordinate
	* @param y region-local y coordinate
	* @param width rectangle width
	* @param height rectangle height
	*/
	add: proc "c" (client: ^client, resource: ^resource, x: i32, y: i32, width: i32, height: i32),

	/**
	* subtract rectangle from region
	*
	* Subtract the specified rectangle from the region.
	* @param x region-local x coordinate
	* @param y region-local y coordinate
	* @param width rectangle width
	* @param height rectangle height
	*/
	subtract: proc "c" (client: ^client, resource: ^resource, x: i32, y: i32, width: i32, height: i32),
}

